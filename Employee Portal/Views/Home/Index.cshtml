@using Employee_Portal.Models
@{
    ViewData["Title"] = "Dashboard";

    int totalEmployees = ViewBag.TotalEmployees ?? 0;
    int totalDepartments = ViewBag.TotalDepartments ?? 0;
    int maleCount = ViewBag.MaleCount ?? 0;
    int femaleCount = ViewBag.FemaleCount ?? 0;

    var recentEmployees = ViewBag.RecentEmployees as List<Employee> ?? new List<Employee>();
}

<!-- ─── Hero Banner ─────────────────────────────────────────────── -->
<div class="rounded-4 text-white p-5 mb-4 d-flex align-items-center justify-content-between flex-wrap gap-3"
     style="background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%); min-height: 160px;">
    <div>
        <h1 class="fw-bold mb-1" style="font-size: 2rem;">
            <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </h1>
        <p class="mb-0 opacity-75">Welcome back, <strong>Admin</strong>. Here's a quick overview of your workforce.</p>
    </div>
    <a asp-controller="Employee" asp-action="Create"
       class="btn btn-light btn-lg fw-semibold shadow-sm px-4">
        <i class="bi bi-person-plus-fill me-2"></i>Add Employee
    </a>
</div>

<!-- ─── Stat Cards ────────────────────────────────────────────────── -->
<div class="row g-4 mb-4">

    <!-- Total Employees -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:56px; height:56px; background:#dbeafe;">
                    <i class="bi bi-people-fill fs-3" style="color:#1d4ed8;"></i>
                </div>
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Total Employees</div>
                    <div class="fw-bold" style="font-size:1.9rem; color:#1e3a8a;">@totalEmployees</div>
                </div>
            </div>
            <div style="height:4px; background:#1d4ed8;"></div>
        </div>
    </div>

    <!-- Departments -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:56px; height:56px; background:#d1fae5;">
                    <i class="bi bi-building fs-3" style="color:#059669;"></i>
                </div>
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Departments</div>
                    <div class="fw-bold" style="font-size:1.9rem; color:#065f46;">@totalDepartments</div>
                </div>
            </div>
            <div style="height:4px; background:#059669;"></div>
        </div>
    </div>

    <!-- Male -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:56px; height:56px; background:#e0e7ff;">
                    <i class="bi bi-gender-male fs-3" style="color:#4f46e5;"></i>
                </div>
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Male</div>
                    <div class="fw-bold" style="font-size:1.9rem; color:#3730a3;">@maleCount</div>
                </div>
            </div>
            <div style="height:4px; background:#4f46e5;"></div>
        </div>
    </div>

    <!-- Female -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:56px; height:56px; background:#fce7f3;">
                    <i class="bi bi-gender-female fs-3" style="color:#db2777;"></i>
                </div>
                <div>
                    <div class="text-muted small fw-semibold text-uppercase">Female</div>
                    <div class="fw-bold" style="font-size:1.9rem; color:#9d174d;">@femaleCount</div>
                </div>
            </div>
            <div style="height:4px; background:#db2777;"></div>
        </div>
    </div>

</div>

<!-- ─── Recent Employees + Quick Actions ────────────────────────── -->
<div class="row g-4">

    <!-- Recent Employees Table -->
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-0 pt-4 pb-2 px-4 d-flex align-items-center justify-content-between">
                <h6 class="fw-bold mb-0" style="color:#1e3a8a;">
                    <i class="bi bi-clock-history me-2"></i>Recently Added Employees
                </h6>
                <a asp-controller="Employee" asp-action="List" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                    View All
                </a>
            </div>
            <div class="card-body p-0">
                @if (!recentEmployees.Any())
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        No employees found. <a asp-controller="Employee" asp-action="Create">Add one now →</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead style="background:#f8fafc;">
                                <tr class="text-muted small text-uppercase">
                                    <th class="px-4 py-3">Name</th>
                                    <th class="py-3">Department</th>
                                    <th class="py-3">Designation</th>
                                    <th class="py-3">Hire Date</th>
                                    <th class="py-3">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var emp in recentEmployees)
                                {
                                    <tr>
                                        <td class="px-4 fw-semibold">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                                                     style="width:36px; height:36px; font-size:0.85rem;
                                                            background: @(emp.Gender == "Female" ? "#db2777" : "#1d4ed8");">
                                                    @emp.FullName.Substring(0, 1).ToUpper()
                                                </div>
                                                @emp.FullName
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge rounded-pill px-3 py-2"
                                                  style="background:#dbeafe; color:#1d4ed8; font-size:0.78rem;">
                                                @emp.Department?.Name
                                            </span>
                                        </td>
                                        <td class="text-muted small">@emp.Designation?.Name</td>
                                        <td class="text-muted small">@emp.HireDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            <a asp-controller="Employee" asp-action="Details" asp-route-id="@emp.Id"
                                               class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                                <i class="bi bi-eye me-1"></i>View
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-0 pt-4 pb-2 px-4">
                <h6 class="fw-bold mb-0" style="color:#1e3a8a;">
                    <i class="bi bi-lightning-charge-fill me-2"></i>Quick Actions
                </h6>
            </div>
            <div class="card-body d-flex flex-column gap-3 px-4 pb-4">

                <a asp-controller="Employee" asp-action="Create"
                   class="btn btn-primary rounded-3 text-start px-4 py-3 d-flex align-items-center gap-3 shadow-sm">
                    <i class="bi bi-person-plus-fill fs-5"></i>
                    <div>
                        <div class="fw-semibold">Add New Employee</div>
                        <small class="opacity-75">Register a new team member</small>
                    </div>
                </a>

                <a asp-controller="Employee" asp-action="List"
                   class="btn btn-outline-primary rounded-3 text-start px-4 py-3 d-flex align-items-center gap-3">
                    <i class="bi bi-table fs-5"></i>
                    <div>
                        <div class="fw-semibold">View Employee List</div>
                        <small class="opacity-75">Browse, search & filter</small>
                    </div>
                </a>

            </div>
        </div>
    </div>

</div>